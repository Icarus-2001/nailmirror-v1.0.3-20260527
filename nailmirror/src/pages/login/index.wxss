.login {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-top: 160rpx;
  text-align: center;
  background: linear-gradient(180deg, #fff5f7 0%, #f7f7fb 100%);
}
.login__logo { font-size: 72rpx; font-weight: 700; color: var(--np-primary); }
.login__subtitle { font-size: 26rpx; color: var(--np-text-weak); margin-top: 16rpx; }
.login__hero {
  display: block;
  width: 360rpx;
  height: 360rpx;
  margin: 64rpx auto 72rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 12rpx 40rpx rgba(255, 94, 138, 0.12);
}
.login__actions {
  margin-top: auto;
  padding-bottom: 48rpx;
}
.login__btn {
  min-height: 88rpx;
  margin-bottom: 24rpx;
}
.login__btn[disabled] {
  opacity: 0.85;
}
.login__skip { color: var(--np-text-weak); font-size: 26rpx; }
.login__policy { color: var(--np-text-weak); font-size: 22rpx; margin-top: 80rpx; }
