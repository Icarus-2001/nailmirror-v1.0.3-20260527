.pp { position: fixed; inset: 0; z-index: 9999; }
.pp__mask { position: absolute; inset: 0; background: rgba(0,0,0,0.45); }
.pp__box {
  position: absolute; left: 48rpx; right: 48rpx; top: 50%;
  transform: translateY(-50%);
  background: #fff; border-radius: 24rpx; padding: 40rpx 36rpx 32rpx;
}
.pp__title { font-size: 34rpx; font-weight: 700; color: #1a1a1a; margin-bottom: 24rpx; }
.pp__body { font-size: 28rpx; color: #555; line-height: 1.7; }
.pp__link { color: #576b95; }
.pp__actions { display: flex; gap: 20rpx; margin-top: 36rpx; }
.pp__btn {
  flex: 1; margin: 0; padding: 0; height: 80rpx; line-height: 80rpx;
  font-size: 28rpx; border-radius: 999rpx;
}
.pp__btn::after { border: none; }
.pp__btn--ghost { background: #f5f5f5; color: #666; }
.pp__btn--primary {
  background: linear-gradient(135deg, #ff5e8a, #9b6cff);
  color: #fff;
}
