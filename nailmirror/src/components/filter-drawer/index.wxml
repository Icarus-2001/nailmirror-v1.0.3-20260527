<view class="fdrawer" wx:if="{{visible}}">
  <view class="fdrawer__mask" bindtap="onClose"></view>
  <view class="fdrawer__panel">
    <view class="fdrawer__title">筛选</view>

    <view class="fdrawer__section">
      <view class="fdrawer__label">风格</view>
      <view class="fdrawer__tags">
        <view wx:for="{{styles}}" wx:key="id" class="fdrawer__tag {{selStyles.indexOf(item.id) > -1 ? 'fdrawer__tag--on' : ''}}" data-v="{{item.id}}" bindtap="onStyleTap">{{item.label}}</view>
      </view>
    </view>

    <view class="fdrawer__section">
      <view class="fdrawer__label">材质</view>
      <view class="fdrawer__tags">
        <view wx:for="{{materials}}" wx:key="id" class="fdrawer__tag {{selMaterials.indexOf(item.id) > -1 ? 'fdrawer__tag--on' : ''}}" data-v="{{item.id}}" bindtap="onMaterialTap">{{item.label}}</view>
      </view>
    </view>

    <view class="fdrawer__section">
      <view class="fdrawer__label">甲型</view>
      <view class="fdrawer__tags">
        <view wx:for="{{shapes}}" wx:key="id" class="fdrawer__tag {{selShapes.indexOf(item.id) > -1 ? 'fdrawer__tag--on' : ''}}" data-v="{{item.id}}" bindtap="onShapeTap">{{item.label}}</view>
      </view>
    </view>

    <view class="fdrawer__actions">
      <view class="np-btn np-btn--ghost" bindtap="onReset">重置</view>
      <view class="np-btn" bindtap="onConfirm">确定</view>
    </view>
  </view>
</view>
