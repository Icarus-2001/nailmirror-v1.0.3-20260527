/* V1.6 主页样式 — 自包含，不依赖外部 cover 图 */
.home {
  min-height: 100vh;
  padding: 24rpx 24rpx 100rpx;
  background: #f7f7fb;
  box-sizing: border-box;
}

.home__hero { padding: 16rpx 8rpx 24rpx; }
.home__greet { font-size: 40rpx; font-weight: 700; color: #1a1a1a; margin-bottom: 8rpx; }
.home__slogan { font-size: 26rpx; color: #888; }

/* 主入口卡 */
.home__main-card {
  background: linear-gradient(135deg, #ff5e8a 0%, #9b6cff 100%);
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(255,94,138,0.24);
  margin-bottom: 24rpx;
}
.home__main-card--hover { opacity: 0.92; }
.home__main-inner { display: flex; align-items: center; }
.home__main-icon {
  width: 100rpx; height: 100rpx; border-radius: 24rpx;
  background: rgba(255,255,255,0.22);
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; margin-right: 24rpx;
}
.home__main-text { flex: 1; color: #fff; }
.home__main-title { font-size: 38rpx; font-weight: 700; margin-bottom: 8rpx; }
.home__main-sub { font-size: 26rpx; opacity: 0.92; }
.home__main-arrow { color: #fff; font-size: 60rpx; line-height: 1; opacity: 0.85; }

/* 副入口三宫格 */
.home__sub-entries {
  display: flex;
  margin-bottom: 36rpx;
}
.home__sub-entry {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 0;
  text-align: center;
  margin-right: 18rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.home__sub-entry:last-child { margin-right: 0; }
.home__sub-icon {
  width: 80rpx; height: 80rpx; border-radius: 20rpx;
  margin: 0 auto 14rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 40rpx; color: #fff;
}
.home__sub-icon--purple { background: #9b6cff; }
.home__sub-icon--orange { background: #f59e0b; }
.home__sub-icon--green  { background: #22c55e; }
.home__sub-label { font-size: 26rpx; color: #333; font-weight: 500; }

/* sections */
.home__section { margin-bottom: 36rpx; }
.home__section-head {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 20rpx; padding: 0 4rpx;
}
.home__section-title { font-size: 34rpx; font-weight: 600; color: #1a1a1a; }
.home__section-more  { font-size: 26rpx; color: #888; }

/* 推荐网格 */
.home__grid { display: flex; flex-wrap: wrap; }
.home__grid-col { width: calc(50% - 10rpx); margin-right: 20rpx; margin-bottom: 20rpx; }
.home__grid-col:nth-child(2n) { margin-right: 0; }

.home__card { background: #fff; border-radius: 20rpx; overflow: hidden; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04); }
.home__card-cover {
  position: relative; width: 100%; height: 240rpx;
  background: #f0f0f5;
  overflow: hidden;
}
.home__card-img {
  width: 100%; height: 100%; display: block;
}
.home__card-emoji {
  font-size: 80rpx;
  position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
}
.home__card-heat {
  position: absolute; top: 12rpx; right: 12rpx;
  padding: 4rpx 14rpx; background: rgba(0,0,0,0.55); color: #fff;
  border-radius: 999rpx; font-size: 20rpx;
}
.home__card-body { padding: 16rpx 20rpx 20rpx; }
.home__card-title {
  font-size: 28rpx; color: #1a1a1a; font-weight: 500;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.home__card-tags { margin-top: 10rpx; display: flex; flex-wrap: wrap; }

.home__tag {
  display: inline-flex; padding: 4rpx 16rpx; border-radius: 999rpx;
  background: #ffd8e3; color: #ff5e8a; font-size: 22rpx;
  margin-right: 8rpx; margin-bottom: 4rpx;
}
.home__tag--mini { font-size: 20rpx; padding: 2rpx 12rpx; }

/* 热门搜索 */
.home__hot-list { background: #fff; border-radius: 20rpx; padding: 8rpx 0; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04); }
.home__hot-item {
  display: flex; align-items: center;
  padding: 20rpx 24rpx; border-bottom: 1rpx solid #f0f0f5;
}
.home__hot-item:last-child { border-bottom: none; }
.home__hot-rank {
  width: 56rpx; height: 56rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 28rpx; margin-right: 20rpx;
}
.home__hot-rank--top    { background: #ff5e8a; color: #fff; }
.home__hot-rank--normal { background: #f0f0f5; color: #888; }
.home__hot-body { flex: 1; }
.home__hot-word { font-size: 30rpx; color: #1a1a1a; font-weight: 500; margin-bottom: 6rpx; }
.home__hot-meta { display: flex; align-items: center; font-size: 22rpx; color: #888; }
.home__hot-heat { margin-left: 8rpx; }

.home__safe-bottom { height: 40rpx; }
