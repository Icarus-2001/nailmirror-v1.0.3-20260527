.login { min-height: 100vh; padding-top: 160rpx; text-align: center; background: linear-gradient(180deg, #fff5f7 0%, #f7f7fb 100%); }
.login__logo { font-size: 72rpx; font-weight: 700; color: var(--np-primary); }
.login__subtitle { font-size: 26rpx; color: var(--np-text-weak); margin-top: 16rpx; }
.login__hero { width: 400rpx; height: 400rpx; background: url(https://picsum.photos/seed/nm-login/400/400) center/cover; border-radius: 32rpx; margin: 80rpx auto; }
.login__actions .np-btn { margin-bottom: 24rpx; }
.login__skip { color: var(--np-text-weak); font-size: 26rpx; }
.login__policy { color: var(--np-text-weak); font-size: 22rpx; margin-top: 80rpx; }
